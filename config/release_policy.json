{
  "schema_version": 1,
  "required_files": [
    "README.md",
    "CHANGELOG.md",
    "scripts/version.py",
    "docs/architecture.md",
    "docs/commands.md",
    "docs/security.md",
    "docs/v3.0-architecture.md",
    "docs/migrations/v3.0.0.md",
    "docs/releases/v3.0.0.md",
    "RELEASE_NOTES.md",
    "config/diagnostics_policy.json",
    "config/release_policy.json",
    ".github/workflows/ci.yml",
    "docs/ci.md",
    "scripts/check_repository_hygiene.py",
    "scripts/run_release_check.py",
    ".tmp/.gitkeep"
  ],
  "branch_policy": {
    "allowed_check_branches": [
      "main"
    ],
    "allowed_check_prefixes": [
      "feature/v",
      "release/"
    ],
    "publish_branch": "main"
  },
  "checks": {
    "documentation": true,
    "commands": [
      "identity",
      "policy-consistency",
      "compile",
      "tests",
      "repository-hygiene"
    ]
  },
  "notes": {
    "source": "CHANGELOG.md",
    "output_dir": "docs/releases",
    "max_chars": 20000
  },
  "publishing": {
    "allow_commit": false,
    "allow_tag": false,
    "allow_push": false,
    "allow_github_release": false
  }
}
