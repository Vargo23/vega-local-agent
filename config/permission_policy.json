{
  "schema_version": 1,
  "default_effect": "deny",
  "confirmation_token": "CONFIRM",
  "max_session_grants": 25,
  "rules": [
    {"tool_name": "apply_patch", "capabilities": ["project.write", "managed_state.write"], "risk": "critical", "effect": "confirm", "session_grant_allowed": false, "reason": "Applies a pending change to project files."},
    {"tool_name": "documentation_build", "capabilities": ["project.read", "documentation.read", "managed_state.write"], "risk": "high", "effect": "confirm", "session_grant_allowed": false, "reason": "Generates persistent pending documentation patches."},
    {"tool_name": "documentation_check", "capabilities": ["project.read", "documentation.read"], "risk": "low", "effect": "allow", "session_grant_allowed": false, "reason": "Reads project documentation state for validation."},
    {"tool_name": "documentation_policy_load", "capabilities": ["documentation.read"], "risk": "low", "effect": "allow", "session_grant_allowed": false, "reason": "Reads the documentation policy."},
    {"tool_name": "documentation_status", "capabilities": ["project.read", "documentation.read"], "risk": "low", "effect": "allow", "session_grant_allowed": false, "reason": "Reads documentation status and project version metadata."},
    {"tool_name": "find_file", "capabilities": ["project.read"], "risk": "low", "effect": "allow", "session_grant_allowed": false, "reason": "Searches for files inside the project."},
    {"tool_name": "git_branch", "capabilities": ["git.read"], "risk": "low", "effect": "allow", "session_grant_allowed": false, "reason": "Reads the current Git branch."},
    {"tool_name": "git_diff", "capabilities": ["git.read", "project.read"], "risk": "low", "effect": "allow", "session_grant_allowed": false, "reason": "Reads unstaged Git differences."},
    {"tool_name": "git_diff_cached", "capabilities": ["git.read", "project.read"], "risk": "low", "effect": "allow", "session_grant_allowed": false, "reason": "Reads staged Git differences."},
    {"tool_name": "git_log", "capabilities": ["git.read"], "risk": "low", "effect": "allow", "session_grant_allowed": false, "reason": "Reads Git history."},
    {"tool_name": "git_status", "capabilities": ["git.read"], "risk": "low", "effect": "allow", "session_grant_allowed": false, "reason": "Reads Git working tree status."},
    {"tool_name": "internet_set", "capabilities": ["network.control", "managed_state.write"], "risk": "high", "effect": "confirm", "session_grant_allowed": false, "reason": "Changes controlled internet availability state."},
    {"tool_name": "internet_status", "capabilities": ["network.control", "managed_state.read"], "risk": "low", "effect": "allow", "session_grant_allowed": false, "reason": "Reads controlled internet availability state."},
    {"tool_name": "list_dir", "capabilities": ["project.read"], "risk": "low", "effect": "allow", "session_grant_allowed": false, "reason": "Lists a directory inside the project."},
    {"tool_name": "list_patches", "capabilities": ["managed_state.read"], "risk": "low", "effect": "allow", "session_grant_allowed": false, "reason": "Lists managed patch records."},
    {"tool_name": "memory_add", "capabilities": ["memory.write", "managed_state.write"], "risk": "medium", "effect": "confirm", "session_grant_allowed": true, "reason": "Persists a new project memory entry."},
    {"tool_name": "memory_list", "capabilities": ["memory.read"], "risk": "low", "effect": "allow", "session_grant_allowed": false, "reason": "Lists project memory entries."},
    {"tool_name": "memory_search", "capabilities": ["memory.read"], "risk": "low", "effect": "allow", "session_grant_allowed": false, "reason": "Searches project memory entries."},
    {"tool_name": "memory_stats", "capabilities": ["memory.read"], "risk": "low", "effect": "allow", "session_grant_allowed": false, "reason": "Reads project memory statistics."},
    {"tool_name": "propose_patch", "capabilities": ["project.read", "managed_state.write"], "risk": "medium", "effect": "confirm", "session_grant_allowed": true, "reason": "Persists a proposed project change without applying it."},
    {"tool_name": "propose_patch_from_file", "capabilities": ["project.read", "managed_state.write"], "risk": "medium", "effect": "confirm", "session_grant_allowed": true, "reason": "Persists a file-backed proposed project change without applying it."},
    {"tool_name": "read_file", "capabilities": ["project.read"], "risk": "low", "effect": "allow", "session_grant_allowed": false, "reason": "Reads a file inside the project."},
    {"tool_name": "release_check", "capabilities": ["release.read", "project.read", "git.read", "process.execute"], "risk": "high", "effect": "confirm", "session_grant_allowed": false, "reason": "Runs configured release-readiness commands."},
    {"tool_name": "release_notes", "capabilities": ["release.read", "project.read"], "risk": "low", "effect": "allow", "session_grant_allowed": false, "reason": "Builds an in-memory release notes draft from project data."},
    {"tool_name": "release_policy_load", "capabilities": ["release.read"], "risk": "low", "effect": "allow", "session_grant_allowed": false, "reason": "Reads the release policy."},
    {"tool_name": "release_status", "capabilities": ["release.read", "project.read", "git.read"], "risk": "low", "effect": "allow", "session_grant_allowed": false, "reason": "Reads release and repository status."},
    {"tool_name": "rollback_patch", "capabilities": ["project.write", "managed_state.write"], "risk": "critical", "effect": "confirm", "session_grant_allowed": false, "reason": "Reverts project files using managed patch state."},
    {"tool_name": "search_in_files", "capabilities": ["project.read"], "risk": "low", "effect": "allow", "session_grant_allowed": false, "reason": "Searches text inside project files."},
    {"tool_name": "show_patch", "capabilities": ["managed_state.read"], "risk": "low", "effect": "allow", "session_grant_allowed": false, "reason": "Reads details of a managed patch."},
    {"tool_name": "summarize_file", "capabilities": ["project.read"], "risk": "low", "effect": "allow", "session_grant_allowed": false, "reason": "Reads and summarizes a project file."},
    {"tool_name": "terminal_list", "capabilities": ["managed_state.read"], "risk": "low", "effect": "allow", "session_grant_allowed": false, "reason": "Lists configured executable command definitions."},
    {"tool_name": "terminal_run", "capabilities": ["process.execute"], "risk": "high", "effect": "confirm", "session_grant_allowed": false, "reason": "Executes a configured operating-system command."},
    {"tool_name": "test_list", "capabilities": ["managed_state.read"], "risk": "low", "effect": "allow", "session_grant_allowed": false, "reason": "Lists configured test groups."},
    {"tool_name": "test_run", "capabilities": ["process.execute", "project.read"], "risk": "high", "effect": "confirm", "session_grant_allowed": false, "reason": "Executes a configured project test group."},
    {"tool_name": "web_fetch", "capabilities": ["network.fetch"], "risk": "high", "effect": "confirm", "session_grant_allowed": false, "reason": "Performs a controlled network request."}
  ]
}
